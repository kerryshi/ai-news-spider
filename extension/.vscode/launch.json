{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run AI Signal Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "${workspaceFolder}/..",
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": ["${workspaceFolder}/out/**/*.js"],
      "preLaunchTask": "npm: compile"
    }
  ]
}
